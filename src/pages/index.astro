---
export const prerender = true;
import { ResumeBuilder } from "../components/ResumeBuilder";
import Layout from "../layouts/Layout.astro";
import { Footer } from "../components/ui/Footer";
---

<Layout>
	<h1 class="sr-only">
		ResumeVibe - Professional ATS-Friendly Resume Builder & AI Optimization Tool
	</h1>

	<!-- Full-viewport editor — all scroll is contained within -->
	<section class="h-[100dvh] overflow-hidden relative">
		<ResumeBuilder client:load />
	</section>

		<!-- ══════════════════════════════════════════════════════════════
	     Below-the-fold: Editorial Marketing Section
	     ══════════════════════════════════════════════════════════════ -->
	<section id="about" class="relative bg-[#F4F3ED] dark:bg-[#0A0A0A] text-[#1A1A1A] dark:text-[#F4F3ED] transition-colors duration-700 selection:bg-[#8B7355] selection:text-[#F4F3ED] pb-24">
		<style>
			@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:ital,wght@0,300;0,400;0,500;1,300&display=swap');
			.font-serif-ed { font-family: 'Cormorant Garamond', serif; }
			.font-sans-ed { font-family: 'Jost', sans-serif; }
			
			.ed-border {
				border-color: rgba(26, 26, 26, 0.15);
			}
			:global(.dark) .ed-border {
				border-color: rgba(244, 243, 237, 0.12);
			}
			.ed-border-heavy {
				border-color: rgba(26, 26, 26, 0.9);
			}
			:global(.dark) .ed-border-heavy {
				border-color: rgba(244, 243, 237, 0.9);
			}

			/* Subtle grain overlay */
			.grain-overlay {
				background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
			}
		</style>

		<!-- Atmospheric noise -->
		<div class="absolute inset-0 opacity-[0.04] dark:opacity-[0.03] grain-overlay pointer-events-none"></div>

		<!-- Top delicate border -->
		<div class="border-t ed-border w-full relative z-10"></div>

		<!-- Issue / Volume Header -->
		<div class="relative z-10 max-w-[100rem] mx-auto px-6 md:px-12 py-5 flex justify-between items-center font-sans-ed text-[11px] uppercase tracking-[0.25em] border-b ed-border">
			<span class="opacity-70">Vol. I — The Anti-Template</span>
			<span class="opacity-70">Editorial By ResumeVibe</span>
			<span class="hidden sm:inline-block opacity-70">Curated Career Presentation</span>
		</div>

		<!-- ── Hero Statement ── -->
		<div class="relative z-10 max-w-[100rem] mx-auto px-6 md:px-12 py-24 md:py-40 grid grid-cols-1 lg:grid-cols-12 gap-16 border-b ed-border">
			<div class="lg:col-span-8 relative z-10">
				<h2 class="font-serif-ed text-[clamp(3.5rem,8vw,9rem)] leading-[0.85] tracking-tight mb-12">
					Your resume <br/>
					<span class="italic text-[#8B7355] dark:text-[#A68F6C] font-light">shouldn't look</span> <br/>
					like everyone else's.
				</h2>
				<div class="flex gap-6 max-w-2xl mt-16 items-start">
					<span class="font-serif-ed text-7xl md:text-8xl leading-[0.7] text-[#8B7355] dark:text-[#A68F6C] mt-2">R</span>
					<p class="font-sans-ed text-lg md:text-2xl leading-relaxed font-light opacity-80">
						esumeVibe is an autonomous career presentation engine. Not another template factory — a system that understands what makes recruiters <em class="font-serif-ed text-3xl lowercase tracking-wide ml-1 opacity-100 italic">actually stop scrolling</em>.
					</p>
				</div>
			</div>
			
			<div class="lg:col-span-4 flex flex-col justify-end">
				<div class="border ed-border p-10 relative overflow-hidden group hover:border-[#8B7355] dark:hover:border-[#A68F6C] transition-colors duration-700 bg-white/50 dark:bg-black/20 backdrop-blur-sm">
					<!-- decorative corner -->
					<div class="absolute top-0 right-0 w-10 h-10 border-l border-b ed-border bg-[#F4F3ED] dark:bg-[#0A0A0A] z-10 transition-colors duration-700 group-hover:border-[#8B7355] dark:group-hover:border-[#A68F6C]"></div>
					<div class="absolute top-2 right-2 w-1.5 h-1.5 bg-[#1A1A1A] dark:bg-[#F4F3ED] rounded-full z-20"></div>
					
					<p class="font-sans-ed text-[10px] uppercase tracking-[0.25em] mb-8 opacity-60">The Metric</p>
					<p class="font-serif-ed text-8xl mb-6 tracking-tighter">40<span class="text-5xl italic text-[#8B7355] dark:text-[#A68F6C] font-light">%</span></p>
					<p class="font-sans-ed text-sm leading-relaxed opacity-75 font-light">
						higher interview rate with single-column, ATS-optimized layouts compared to multi-column "aesthetic" designs.
					</p>
				</div>
			</div>
		</div>

		<!-- ── Manifesto / Features Layout ── -->
		<div class="relative z-10 max-w-[100rem] mx-auto px-6 md:px-12 py-32 grid grid-cols-1 md:grid-cols-3 gap-x-16 gap-y-20 border-b ed-border">
			
			<!-- Feature 1 -->
			<div class="col-span-1 border-t-[3px] ed-border-heavy pt-6 relative group">
				<div class="font-sans-ed text-[10px] uppercase tracking-[0.2em] mb-16 flex justify-between opacity-60">
					<span>Chapter I</span>
					<span>Parse Rate</span>
				</div>
				<h3 class="font-serif-ed text-4xl mb-6 tracking-tight group-hover:italic transition-all duration-300">Flawless Extraction</h3>
				<p class="font-sans-ed text-base leading-relaxed opacity-75 font-light">
					Tested against Greenhouse, Workday, Lever, and iCIMS. Our strict single-column architecture guarantees a perfect parse, preserving your narrative precisely as intended.
				</p>
			</div>
			
			<!-- Feature 2 -->
			<div class="col-span-1 border-t-[3px] ed-border-heavy pt-6 relative group">
				<div class="font-sans-ed text-[10px] uppercase tracking-[0.2em] mb-16 flex justify-between opacity-60">
					<span>Chapter II</span>
					<span>AI Rewriting</span>
				</div>
				<h3 class="font-serif-ed text-4xl mb-6 tracking-tight group-hover:italic transition-all duration-300">Algorithmic Precision</h3>
				<p class="font-sans-ed text-base leading-relaxed opacity-75 font-light">
					One-click optimization. Quantifies impact, injects action verbs, and matches keyword density to your target job description with editorial restraint.
				</p>
			</div>

			<!-- Feature 3 -->
			<div class="col-span-1 border-t-[3px] ed-border-heavy pt-6 relative group">
				<div class="font-sans-ed text-[10px] uppercase tracking-[0.2em] mb-16 flex justify-between opacity-60">
					<span>Chapter III</span>
					<span>Live Canvas</span>
				</div>
				<h3 class="font-serif-ed text-4xl mb-6 tracking-tight group-hover:italic transition-all duration-300">Direct Manipulation</h3>
				<p class="font-sans-ed text-base leading-relaxed opacity-75 font-light">
					Edit directly on the preview. Keyboard-first interactions for those who think faster than they click. What you see is exactly what they read.
				</p>
			</div>
		</div>

		<!-- ── FAQ Section Editorial Style ── -->
		<div class="relative z-10 max-w-[100rem] mx-auto px-6 md:px-12 py-32 grid grid-cols-1 lg:grid-cols-12 gap-16 border-b ed-border">
			<div class="lg:col-span-4">
				<div class="sticky top-24">
					<p class="font-sans-ed text-[10px] uppercase tracking-[0.2em] mb-8 opacity-60">Inquiries</p>
					<h3 class="font-serif-ed text-[clamp(3rem,4vw,4.5rem)] leading-[0.9]">Frequently<br/><span class="italic text-[#8B7355] dark:text-[#A68F6C]">Asked</span></h3>
				</div>
			</div>
			
			<div class="lg:col-span-8 flex flex-col pt-4">
				<details class="group border-b ed-border pb-10 mb-10 last:border-b-0 last:mb-0 last:pb-0" open>
					<summary class="list-none cursor-pointer flex justify-between items-center font-serif-ed text-3xl hover:italic transition-all duration-300">
						Is ResumeVibe really free?
						<span class="font-sans-ed text-sm opacity-40 group-open:rotate-45 transition-transform duration-500">+</span>
					</summary>
					<div class="overflow-hidden">
						<p class="font-sans-ed text-lg mt-6 opacity-75 max-w-2xl leading-relaxed font-light">
							Yes. Building, saving, and exporting unlimited resumes is free forever.
							Premium AI features (bulk optimization, career coaching) use a token system
							with generous free allocations.
						</p>
					</div>
				</details>
				
				<details class="group border-b ed-border pb-10 mb-10 last:border-b-0 last:mb-0 last:pb-0">
					<summary class="list-none cursor-pointer flex justify-between items-center font-serif-ed text-3xl hover:italic transition-all duration-300">
						Will optimized resumes look bad to humans?
						<span class="font-sans-ed text-sm opacity-40 group-open:rotate-45 transition-transform duration-500">+</span>
					</summary>
					<div class="overflow-hidden">
						<p class="font-sans-ed text-lg mt-6 opacity-75 max-w-2xl leading-relaxed font-light">
							No. Our design system is built to look premium to both machines and people.
							Clean typography, precise spacing, and professional hierarchy — the same things
							that make ATS happy also make recruiters impressed.
						</p>
					</div>
				</details>
				
				<details class="group border-b ed-border pb-10 mb-10 last:border-b-0 last:mb-0 last:pb-0">
					<summary class="list-none cursor-pointer flex justify-between items-center font-serif-ed text-3xl hover:italic transition-all duration-300">
						Can I import my existing resume?
						<span class="font-sans-ed text-sm opacity-40 group-open:rotate-45 transition-transform duration-500">+</span>
					</summary>
					<div class="overflow-hidden">
						<p class="font-sans-ed text-lg mt-6 opacity-75 max-w-2xl leading-relaxed font-light">
							Yes. Upload a PDF or paste plain text and our parser will extract your
							information into structured sections. You can then edit and optimize
							everything in the live editor.
						</p>
					</div>
				</details>
			</div>
		</div>

		<!-- ── Footer CTA ── -->
		<div class="relative z-10 max-w-[100rem] mx-auto px-6 md:px-12 py-32 flex flex-col md:flex-row justify-between items-center gap-12">
			<div>
				<p class="font-sans-ed text-[10px] uppercase tracking-[0.2em] mb-4 opacity-60">The Next Step</p>
				<h3 class="font-serif-ed text-5xl md:text-6xl tracking-tight">Ready to <span class="italic text-[#8B7355] dark:text-[#A68F6C]">Commence?</span></h3>
			</div>
			
			<div class="flex flex-col sm:flex-row gap-6">
				<a href="/why-resumevibe" class="font-sans-ed text-[11px] uppercase tracking-[0.2em] border-b border-transparent hover:border-[#1A1A1A] dark:hover:border-[#F4F3ED] transition-colors pb-1 opacity-70 hover:opacity-100 self-center">
					Why ResumeVibe
				</a>
				<a href="/ats-resume-guide" class="font-sans-ed text-[11px] uppercase tracking-[0.2em] border-b border-transparent hover:border-[#1A1A1A] dark:hover:border-[#F4F3ED] transition-colors pb-1 opacity-70 hover:opacity-100 self-center">
					ATS Guide
				</a>
				<a href="#" onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;" class="group relative inline-flex items-center justify-center px-10 py-5 font-sans-ed text-[11px] uppercase tracking-[0.25em] font-medium border border-[#1A1A1A] dark:border-[#F4F3ED] hover:bg-[#1A1A1A] hover:text-[#F4F3ED] dark:hover:bg-[#F4F3ED] dark:hover:text-[#0A0A0A] transition-all duration-500 ml-4">
					<span class="relative z-10 tracking-[0.25em]">Back to Editor</span>
				</a>
			</div>
		</div>
	</section>

	<Footer client:load />
</Layout>
