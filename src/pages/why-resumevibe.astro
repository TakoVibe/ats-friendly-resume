---
export const prerender = true;
import SEO from "../components/SEO.astro";
import "../styles/global.css";
import {
    Sparkles,
    Zap,
    Shield,
    Target,
    Globe,
    Cpu,
    BarChart3,
    Rocket,
    MessageSquare,
    ArrowRight,
    BookOpen,
} from "lucide-react";
---

<html lang="en">
    <head>
        <SEO
            title="Why ResumeVibe? | The Future of Career Presentation"
            description="Discover why ResumeVibe is the most advanced AI-powered resume builder for modern engineering and tech professionals."
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Outfit:wght@400;500;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
            rel="stylesheet"
        />
    </head>
    <body class="bg-[#09090b] text-white selection:bg-purple-500/30">
        <!-- Background Orbs -->
        <div class="fixed inset-0 overflow-hidden pointer-events-none z-0">
            <div
                class="absolute -top-[10%] -left-[10%] w-[40%] h-[40%] bg-purple-600/20 rounded-full blur-[120px] animate-pulse"
            >
            </div>
            <div
                class="absolute top-[20%] -right-[10%] w-[35%] h-[35%] bg-blue-600/15 rounded-full blur-[100px] animate-pulse"
                style="animation-delay: 2s;"
            >
            </div>
            <div
                class="absolute -bottom-[10%] left-[20%] w-[30%] h-[30%] bg-indigo-600/20 rounded-full blur-[110px] animate-pulse"
                style="animation-delay: 4s;"
            >
            </div>
        </div>

        <main class="relative z-10 max-w-7xl mx-auto px-6 py-20 lg:py-32">
            <!-- Navigation Back -->
            <nav
                class="mb-16 animate-in fade-in slide-in-from-top-4 duration-700"
            >
                <a
                    href="/"
                    class="group flex items-center gap-2 text-[var(--text-muted)] hover:text-white transition-colors"
                >
                    <div
                        class="w-8 h-8 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:border-purple-500/50 transition-all"
                    >
                        <ArrowRight size={16} className="rotate-180" />
                    </div>
                    <span class="text-xs font-black uppercase tracking-widest"
                        >Back to Builder</span
                    >
                </a>
            </nav>

            <!-- Hero Section -->
            <header
                class="mb-32 max-w-3xl animate-in fade-in slide-in-from-bottom-8 duration-1000"
            >
                <div
                    class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-purple-500/10 border border-purple-500/20 mb-8"
                >
                    <Sparkles size={12} className="text-purple-500" />
                    <span
                        class="text-[9px] font-black uppercase tracking-ultra text-purple-400"
                        >The New Standard</span
                    >
                </div>
                <h1
                    class="text-5xl lg:text-7xl font-black tracking-tighter mb-8 bg-gradient-to-r from-white via-white to-white/40 bg-clip-text text-transparent"
                >
                    Why settle for a <span class="text-purple-500">Static</span> Resume?
                </h1>
                <p
                    class="text-xl text-[var(--text-muted)] leading-relaxed font-medium"
                >
                    ResumeVibe isn't just a builder. It's an autonomous career
                    presentation engine designed for high-stakes engineering
                    roles where precision meets aesthetics.
                </p>
            </header>

            <!-- Features Grid -->
            <section class="mb-24">
                <div class="flex items-center gap-4 mb-16">
                    <h2
                        class="text-xs font-black uppercase tracking-ultra text-purple-500"
                    >
                        Active Core Features
                    </h2>
                    <div
                        class="h-[1px] flex-1 bg-gradient-to-r from-purple-500/50 to-transparent"
                    >
                    </div>
                </div>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
                >
                    {
                        [
                            {
                                icon: Cpu,
                                title: "Power Autopilot",
                                desc: "Our AI doesn't just suggest; it executes. One click to analyze job gaps and rewrite your experience for maximum impact.",
                                color: "purple",
                            },
                            {
                                icon: BarChart3,
                                title: "Deep AI Audit",
                                desc: "Get a brutal, honest diagnostic of your resume from a simulated recruiter's perspective before you ever hit send.",
                                color: "blue",
                            },
                            {
                                icon: Target,
                                title: "Real-time Heatmap",
                                desc: "Visualize your keyword match rate as you type. Know exactly which technical terms are missing for your target role.",
                                color: "indigo",
                            },
                            {
                                icon: Zap,
                                title: "Smart PDF Parsing",
                                desc: "Import your old, messy PDF and watch our high-performance parser convert it into a structured, clean data model instantly.",
                                color: "rose",
                            },
                            {
                                icon: Shield,
                                title: "ATS-Safe Engine",
                                desc: "Built with a single-column architecture that guarantees 100% read rates across all major Applicant Tracking Systems.",
                                color: "green",
                            },
                            {
                                icon: MessageSquare,
                                title: "WYSIWYG Precision",
                                desc: "A distraction-free, high-performance editor that lets you focus on your content with instant PDF preview resolution.",
                                color: "amber",
                            },
                        ].map((feat, i) => (
                            <div
                                class="group p-8 rounded-[2.5rem] bg-white/[0.02] border border-white/10 hover:border-purple-500/30 hover:bg-white/[0.04] transition-all duration-500 animate-in fade-in slide-in-from-bottom-8"
                                style={`animation-delay: ${i * 100}ms`}
                            >
                                <div
                                    class={`w-14 h-14 rounded-2xl bg-white/5 flex items-center justify-center mb-8 group-hover:scale-110 group-hover:bg-purple-500/10 transition-all duration-500 shadow-xl`}
                                >
                                    <feat.icon
                                        size={24}
                                        className="text-white group-hover:text-purple-500 transition-colors"
                                    />
                                </div>
                                <h3 class="text-xl font-black mb-4 tracking-tight group-hover:text-purple-500 transition-colors">
                                    {feat.title}
                                </h3>
                                <p class="text-[var(--text-muted)] font-medium leading-relaxed group-hover:text-white/80 transition-colors">
                                    {feat.desc}
                                </p>
                            </div>
                        ))
                    }
                </div>
            </section>

            <!-- Upcoming Features Section -->
            <section class="mb-24 relative group">
                <div
                    class="absolute -inset-4 bg-gradient-to-r from-purple-500/10 to-transparent blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-1000"
                >
                </div>

                <div
                    class="relative p-12 lg:p-20 rounded-[4rem] bg-gradient-to-br from-white/[0.03] to-transparent border border-white/10 overflow-hidden"
                >
                    <div class="flex items-center gap-4 mb-20">
                        <h2
                            class="text-xs font-black uppercase tracking-ultra text-blue-400"
                        >
                            Roadmap: The Next Wave
                        </h2>
                        <div
                            class="h-[1px] flex-1 bg-gradient-to-r from-blue-500/50 to-transparent"
                        >
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
                        <div class="space-y-12">
                            <div class="flex gap-6 items-start">
                                <div
                                    class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center shrink-0"
                                >
                                    <Globe
                                        size={20}
                                        className="text-blue-500"
                                    />
                                </div>
                                <div>
                                    <h4
                                        class="text-lg font-black mb-2 tracking-tight"
                                    >
                                        Standalone Social Portfolios
                                    </h4>
                                    <p
                                        class="text-[var(--text-muted)] font-medium leading-relaxed"
                                    >
                                        Forget file attachments. Generate a
                                        lightning-fast, interactive URL that
                                        works perfectly on LinkedIn and Twitter.
                                    </p>
                                </div>
                            </div>
                            <div class="flex gap-6 items-start">
                                <div
                                    class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center shrink-0"
                                >
                                    <Rocket
                                        size={20}
                                        className="text-blue-500"
                                    />
                                </div>
                                <div>
                                    <h4
                                        class="text-lg font-black mb-2 tracking-tight"
                                    >
                                        One-Click Identity Switch
                                    </h4>
                                    <p
                                        class="text-[var(--text-muted)] font-medium leading-relaxed"
                                    >
                                        Instantly transform your resume's visual
                                        DNA. Toggle between minimalist,
                                        creative, and executive themes with zero
                                        re-formatting.
                                    </p>
                                </div>
                            </div>
                        </div>
                        <div
                            class="bg-blue-500/5 rounded-[3rem] p-8 border border-blue-500/10 flex flex-col justify-center items-center text-center"
                        >
                            <div
                                class="w-20 h-20 rounded-full bg-blue-500/20 flex items-center justify-center mb-6 animate-bounce overflow-hidden border-2 border-blue-500/20"
                            >
                                <img
                                    src="/logo.png"
                                    class="w-full h-full object-cover"
                                    alt="Logo"
                                />
                            </div>
                            <h3
                                class="text-2xl font-black mb-4 px-4 bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent"
                            >
                                We're just getting started.
                            </h3>
                            <p
                                class="text-sm text-[var(--text-muted)] font-medium max-w-xs leading-relaxed"
                            >
                                Experience a resume builder that understands
                                engineering depth. Build your next career move
                                with unmatched precision.
                            </p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- TakoVibe Ecosystem Promo -->
            <section class="mb-24">
                <div
                    class="relative p-1 px-1 rounded-[3rem] bg-gradient-to-r from-purple-500/20 via-blue-500/20 to-purple-500/20"
                >
                    <div
                        class="relative bg-[#09090b] rounded-[2.9rem] p-12 lg:p-20 overflow-hidden"
                    >
                        <!-- Abstract background elements -->
                        <div
                            class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-purple-500/5 to-transparent"
                        >
                        </div>

                        <div
                            class="relative z-10 flex flex-col lg:flex-row items-center gap-16"
                        >
                            <div
                                class="flex-1 space-y-8 text-center lg:text-left"
                            >
                                <div
                                    class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-white/5 border border-white/10"
                                >
                                    <Globe
                                        size={14}
                                        className="text-purple-400"
                                    />
                                    <span
                                        class="text-[10px] font-black uppercase tracking-widest text-purple-300"
                                        >The Parent Ecosystem</span
                                    >
                                </div>
                                <h1
                                    class="text-4xl lg:text-6xl font-black tracking-tighter leading-tight mt-4"
                                >
                                    The Intelligent <br />
                                    <span
                                        class="bg-gradient-to-r from-purple-400 to-blue-400 bg-clip-text text-transparent"
                                        >Knowledge Platform.</span
                                    >
                                </h1>
                                <p
                                    class="text-lg text-[var(--text-muted)] font-medium max-w-2xl leading-relaxed"
                                >
                                    Don't just read. <strong
                                        >Experience it.</strong
                                    > Transform how you learn with interactive mental
                                    models, visual code execution, and AI tutors.
                                </p>

                                <div
                                    class="grid grid-cols-1 sm:grid-cols-2 gap-8 text-left py-4"
                                >
                                    <div class="space-y-3">
                                        <div
                                            class="flex items-center gap-2 text-white font-bold text-sm tracking-tight"
                                        >
                                            <BookOpen
                                                size={18}
                                                className="text-purple-400"
                                            />
                                            High-Depth Topics
                                        </div>
                                        <p
                                            class="text-[11px] text-[var(--text-muted)] font-medium leading-relaxed opacity-80"
                                        >
                                            We create high-quality engineering
                                            topics. From containers to webframes
                                            and core python, we decode the
                                            toughest concepts.
                                        </p>
                                    </div>
                                    <div class="space-y-3">
                                        <div
                                            class="flex items-center gap-2 text-white font-bold text-sm tracking-tight"
                                        >
                                            <Cpu
                                                size={18}
                                                className="text-blue-400"
                                            />
                                            Visual Execution
                                        </div>
                                        <p
                                            class="text-[11px] text-[var(--text-muted)] font-medium leading-relaxed opacity-80"
                                        >
                                            See the invisible. Watch code run
                                            step-by-step with real-time variable
                                            inspection and mental models.
                                        </p>
                                    </div>
                                </div>
                                <div
                                    class="flex flex-wrap justify-center lg:justify-start gap-4 pt-8"
                                >
                                    <a
                                        href="https://takovibe.com"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="group flex items-center gap-3 px-10 py-5 bg-white text-black rounded-2xl font-black text-xs uppercase tracking-[0.2em] hover:bg-purple-500 hover:text-white transition-all duration-500 shadow-2xl shadow-white/5 active:scale-95"
                                    >
                                        Start Learning <ArrowRight
                                            size={18}
                                            className="group-hover:translate-x-2 transition-transform duration-500"
                                        />
                                    </a>
                                </div>
                            </div>

                            <div
                                class="w-full lg:w-[450px] aspect-square relative group"
                            >
                                <div
                                    class="absolute inset-0 bg-gradient-to-br from-purple-500/30 to-blue-500/30 rounded-[4rem] blur-3xl group-hover:opacity-100 opacity-40 transition-opacity duration-1000"
                                >
                                </div>
                                <div
                                    class="relative h-full bg-white/[0.02] border border-white/10 rounded-[4rem] flex items-center justify-center p-12 backdrop-blur-2xl group-hover:bg-white/[0.04] transition-all duration-700 shadow-2xl"
                                >
                                    <div class="flex flex-col items-center">
                                        <span
                                            class="text-4xl font-black tracking-tighter mb-2 bg-gradient-to-b from-white to-white/60 bg-clip-text text-transparent"
                                            >TakoVibe</span
                                        >
                                        <div
                                            class="flex items-center gap-3 px-4 py-1.5 rounded-full bg-green-500/10 border border-green-500/20 mt-4"
                                        >
                                            <div
                                                class="w-2 h-2 rounded-full bg-green-500 animate-pulse shadow-[0_0_8px_rgba(34,197,94,0.6)]"
                                            >
                                            </div>
                                            <span
                                                class="text-[9px] font-black uppercase tracking-ultra text-green-400"
                                                >Live Engineering HQ</span
                                            >
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        </main>

        <!-- Call to Action -->
        <footer
            class="text-center animate-in fade-in slide-in-from-bottom-4 duration-1000 pb-20"
        >
            <a
                href="/"
                class="inline-flex items-center gap-4 px-12 py-6 bg-gradient-to-r from-purple-600 to-blue-600 rounded-[2rem] text-white text-xl font-black uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-2xl shadow-purple-500/30"
            >
                Build Your Edge <ArrowRight size={24} />
            </a>
            <p
                class="mt-8 text-[var(--text-muted)] text-sm font-black uppercase tracking-[0.2em] opacity-40"
            >
                Propelled by TakoVibe Engineering Ecosystem
            </p>
            <div
                class="mt-12 flex flex-col items-center gap-2 text-[var(--text-muted)] text-[10px] font-bold uppercase tracking-widest opacity-30"
            >
                <p>© 2026 TakoVibe</p>
                <p>made with love in india</p>
            </div>
        </footer>
    </body>
</html>
